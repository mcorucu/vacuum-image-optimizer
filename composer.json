{
  "name": "vacuum/vacuum-image-optimizer",
  "description": "Modern image optimization toolkit for WordPress. Generate WebP and AVIF variants, automate optimization workflows, optimize media libraries in bulk, and improve frontend delivery.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Mehmet Can Orucu",
      "homepage": "https://mcorucu.com"
    }
  ],
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "^3.9",
    "wp-coding-standards/wpcs": "^3.0",
    "phpcompatibility/php-compatibility": "^9.3",
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "VacuumImageOptimizer\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "VacuumImageOptimizer\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "phpcs": "phpcs --standard=WordPress src/ vacuum-image-optimizer.php",
    "phpcbf": "phpcbf --standard=WordPress src/ vacuum-image-optimizer.php",
    "phpunit": "phpunit --configuration phpunit.xml"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}

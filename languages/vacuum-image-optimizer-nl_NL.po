msgid "Vacuum Image Optimizer"
msgstr "Vacuum Image Optimizer"

msgid "Vacuum Optimizer"
msgstr "Vacuum Optimizer"

msgid "Sorry, you are not allowed to access this page."
msgstr "Sorry, je hebt geen toestemming om deze pagina te openen."

msgid "Modern image optimization for WordPress — WebP &amp; AVIF generation, bulk tools, and clean delivery."
msgstr "Moderne afbeeldingsoptimalisatie voor WordPress — WebP- &amp; AVIF-generatie, bulkhulpmiddelen en nette levering."

msgid "Vacuum Optimizer Sections"
msgstr "Vacuum Optimizer-secties"

msgid "Dashboard"
msgstr "Dashboard"

msgid "Bulk Optimize"
msgstr "Bulkoptimalisatie"

msgid "WebP & AVIF"
msgstr "WebP & AVIF"

msgid "Compression"
msgstr "Compressie"

msgid "Lazy Load"
msgstr "Lui laden"

msgid "Backup & Restore"
msgstr "Back-up en herstel"

msgid "Exclusions"
msgstr "Uitsluitingen"

msgid "Reports"
msgstr "Rapporten"

msgid "System Status"
msgstr "Systeemstatus"

msgid "This feature is coming soon."
msgstr "Deze functie komt binnenkort beschikbaar."

msgid "Sorry, you are not allowed to manage these settings."
msgstr "Sorry, je hebt geen toestemming om deze instellingen te beheren."

msgid "Backups are disabled. New optimizations will not create restore points, and restore actions for images without an existing backup will be unavailable. Existing backups remain untouched."
msgstr "Back-ups zijn uitgeschakeld. Nieuwe optimalisaties maken geen herstelpunten aan en het herstellen van afbeeldingen zonder bestaande back-up is niet beschikbaar. Bestaande back-ups blijven ongewijzigd."

msgid "Enable Backups"
msgstr "Back-ups inschakelen"

msgid "Keep a copy of each original image before generating optimized formats so it can be restored later."
msgstr "Bewaar een kopie van elke originele afbeelding voordat geoptimaliseerde formaten worden gegenereerd, zodat deze later kan worden hersteld."

msgid "Backup Location"
msgstr "Back-uplocatie"

msgid "Uploads directory unavailable"
msgstr "Uploadmap niet beschikbaar"

msgid "Save Settings"
msgstr "Instellingen opslaan"

msgid "Bulk Optimization"
msgstr "Bulkoptimalisatie"

msgid "Scan eligible JPEG and PNG images, then process the queue in safe WordPress AJAX batches."
msgstr "Scan geschikte JPEG- en PNG-afbeeldingen en verwerk de wachtrij vervolgens in veilige WordPress-AJAX-batches."

msgid "Scan Library"
msgstr "Bibliotheek scannen"


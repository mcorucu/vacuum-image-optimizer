msgid "Vacuum Image Optimizer requires PHP 8.1 or higher."
msgstr "Vacuum Image Optimizer wymaga PHP 8.1 lub nowszego."

msgid "Plugin Activation Error"
msgstr "Błąd aktywacji wtyczki"

msgid "Invalid attachment ID."
msgstr "Nieprawidłowy identyfikator załącznika."

msgid "Attachment could not be found."
msgstr "Nie można znaleźć załącznika."

msgid "This attachment format is not supported for AVIF generation."
msgstr "Ten format załącznika nie jest obsługiwany przy generowaniu AVIF."

msgid "AVIF generation is not available on this server."
msgstr "Generowanie AVIF nie jest dostępne na tym serwerze."

msgid "The original image path could not be resolved."
msgstr "Nie udało się ustalić ścieżki oryginalnego obrazu."

msgid "The original image file is missing or unreadable."
msgstr "Plik oryginalnego obrazu jest brakujący lub nieczytelny."

msgid "The original image file size could not be read."
msgstr "Nie udało się odczytać rozmiaru pliku oryginalnego obrazu."

msgid "The AVIF output path could not be created."
msgstr "Nie udało się utworzyć ścieżki wyjściowej AVIF."

msgid "Existing AVIF file found. Metadata was refreshed."
msgstr "Znaleziono istniejący plik AVIF. Metadane zostały odświeżone."

msgid "No available image engine can generate AVIF on this server."
msgstr "Żaden dostępny silnik graficzny nie może wygenerować AVIF na tym serwerze."

msgid "AVIF generation failed with the available image engines."
msgstr "Generowanie AVIF nie powiodło się przy użyciu dostępnych silników graficznych."

msgid "The generated AVIF file size could not be read."
msgstr "Nie udało się odczytać rozmiaru wygenerowanego pliku AVIF."

msgid "AVIF image generated successfully."
msgstr "Obraz AVIF został wygenerowany pomyślnie."

msgid "The original backup file is missing or unreadable."
msgstr "Plik oryginalnej kopii zapasowej jest brakujący lub nieczytelny."

msgid "The attachment original path could not be resolved."
msgstr "Nie udało się ustalić oryginalnej ścieżki załącznika."

msgid "The original image directory could not be created."
msgstr "Nie udało się utworzyć katalogu oryginalnego obrazu."

msgid "The original image could not be restored from backup."
msgstr "Nie udało się przywrócić oryginalnego obrazu z kopii zapasowej."

msgid "Original image restored successfully."
msgstr "Oryginalny obraz został przywrócony pomyślnie."

msgid "This attachment format is not supported for WebP generation."
msgstr "Ten format załącznika nie jest obsługiwany przy generowaniu WebP."

msgid "The WebP output path could not be created."
msgstr "Nie udało się utworzyć ścieżki wyjściowej WebP."

msgid "The original image backup could not be created."
msgstr "Nie udało się utworzyć kopii zapasowej oryginalnego obrazu."

msgid "Existing WebP file found. Metadata was refreshed."
msgstr "Znaleziono istniejący plik WebP. Metadane zostały odświeżone."

msgid "No available image engine can generate WebP on this server."
msgstr "Żaden dostępny silnik graficzny nie może wygenerować WebP na tym serwerze."

msgid "WebP generation failed with the available image engines."
msgstr "Generowanie WebP nie powiodło się przy użyciu dostępnych silników graficznych."

msgid "The generated WebP file size could not be read."
msgstr "Nie udało się odczytać rozmiaru wygenerowanego pliku WebP."

msgid "WebP image generated successfully."
msgstr "Obraz WebP został wygenerowany pomyślnie."

msgid "Sorry, you are not allowed to manage this attachment."
msgstr "Przepraszamy, nie masz uprawnień do zarządzania tym załącznikiem."

msgid "Backups are disabled, so no backup is available to restore this image. Enable backups before optimizing to allow restores."
msgstr "Kopie zapasowe są wyłączone, więc nie ma kopii do przywrócenia tego obrazu. Włącz kopie zapasowe przed optymalizacją, aby umożliwić przywracanie."

msgid "Existing WebP file could not be deleted before regeneration."
msgstr "Nie udało się usunąć istniejącego pliku WebP przed ponownym generowaniem."

msgid "WebP generation could not be completed."
msgstr "Nie udało się ukończyć generowania WebP."

msgid "AVIF generation could not be completed."
msgstr "Nie udało się ukończyć generowania AVIF."

msgid "WebP regeneration could not be completed."
msgstr "Nie udało się ukończyć ponownego generowania WebP."

msgid "Original image restore could not be completed."
msgstr "Nie udało się ukończyć przywracania oryginalnego obrazu."

msgid "The requested attachment action is invalid."
msgstr "Żądana akcja załącznika jest nieprawidłowa."

msgid "Vacuum Image Optimizer actions are available for image attachments only."
msgstr "Akcje Vacuum Image Optimizer są dostępne tylko dla załączników będących obrazami."


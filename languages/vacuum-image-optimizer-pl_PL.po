msgid "Maximum quality, minimal compression."
msgstr "Maksymalna jakość, minimalna kompresja."

msgid "Best speed to size ratio."
msgstr "Najlepszy stosunek szybkości do rozmiaru."

msgid "Stronger size reduction for most images."
msgstr "Silniejsze zmniejszenie rozmiaru dla większości obrazów."

msgid "Smallest files with the most compression."
msgstr "Najmniejsze pliki z najsilniejszą kompresją."


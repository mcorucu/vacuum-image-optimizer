msgid "Sorry, you are not allowed to manage compression settings."
msgstr "Sie sind nicht berechtigt, Komprimierungseinstellungen zu verwalten."

msgid "Compression Settings"
msgstr "Komprimierungseinstellungen"

msgid "Choose the compression profile and WebP quality used for manual WebP generation and regeneration."
msgstr "Wählen Sie das Komprimierungsprofil und die WebP-Qualität für die manuelle WebP-Erzeugung und -Neuerzeugung."

msgid "Compression Profile"
msgstr "Komprimierungsprofil"

msgid "Quality"
msgstr "Qualität"

msgid "Higher values preserve more visual detail. Lower values usually reduce file size more aggressively."
msgstr "Höhere Werte erhalten mehr visuelle Details. Niedrigere Werte reduzieren die Dateigröße in der Regel stärker."

msgid "Upload Automation"
msgstr "Upload-Automatisierung"

msgid "Enable auto optimization for new uploads"
msgstr "Automatische Optimierung für neue Uploads aktivieren"

msgid "Automatically optimize new JPEG and PNG uploads."
msgstr "Neue JPEG- und PNG-Uploads automatisch optimieren."

msgid "Auto optimization mode"
msgstr "Modus der automatischen Optimierung"

msgid "Queue new uploads"
msgstr "Neue Uploads in die Warteschlange stellen"

msgid "New uploads are added to the optimization queue. You can process them from Bulk Optimize."
msgstr "Neue Uploads werden der Optimierungs-Warteschlange hinzugefügt. Sie können sie über die Massenoptimierung verarbeiten."

msgid "Optimize immediately"
msgstr "Sofort optimieren"

msgid "New uploads are optimized immediately after upload. Large uploads may take longer."
msgstr "Neue Uploads werden sofort nach dem Hochladen optimiert. Große Uploads können länger dauern."

msgid "AVIF Generation"
msgstr "AVIF-Erzeugung"

msgid "Enable AVIF Generation"
msgstr "AVIF-Erzeugung aktivieren"

msgid "AVIF typically provides smaller file sizes than WebP but may require more processing time."
msgstr "AVIF bietet in der Regel kleinere Dateigrößen als WebP, kann aber mehr Verarbeitungszeit erfordern."

msgid "AVIF Quality"
msgstr "AVIF-Qualität"

msgid "Lower AVIF quality values usually reduce file size further. Range: 0–100."
msgstr "Niedrigere AVIF-Qualitätswerte reduzieren die Dateigröße in der Regel weiter. Bereich: 0–100."

msgid "Frontend Delivery"
msgstr "Frontend-Auslieferung"

msgid "Enable Frontend Delivery"
msgstr "Frontend-Auslieferung aktivieren"

msgid "Serve generated WebP/AVIF images on the frontend. Original media files are never modified and the browser always falls back to the original when a derivative is unavailable."
msgstr "Erzeugte WebP-/AVIF-Bilder im Frontend ausliefern. Original-Mediendateien werden nie verändert und der Browser greift immer auf das Original zurück, wenn keine Ableitung verfügbar ist."

msgid "Preferred Format"
msgstr "Bevorzugtes Format"

msgid "Auto"
msgstr "Automatisch"

msgid "AVIF"
msgstr "AVIF"

msgid "WebP"
msgstr "WebP"

msgid "Auto: Serve AVIF when available, otherwise WebP, otherwise the original image."
msgstr "Automatisch: AVIF ausliefern, wenn verfügbar, sonst WebP, sonst das Originalbild."

msgid "AVIF: Prefer AVIF and fall back to the original image."
msgstr "AVIF: AVIF bevorzugen und auf das Originalbild zurückgreifen."

msgid "WebP: Prefer WebP and fall back to the original image."
msgstr "WebP: WebP bevorzugen und auf das Originalbild zurückgreifen."


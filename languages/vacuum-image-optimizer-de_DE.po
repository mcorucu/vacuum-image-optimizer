msgid "Existing AVIF file found. Metadata was refreshed."
msgstr "Vorhandene AVIF-Datei gefunden. Metadaten wurden aktualisiert."

msgid "No available image engine can generate AVIF on this server."
msgstr "Auf diesem Server kann kein verfügbares Bildmodul AVIF erzeugen."

msgid "AVIF generation failed with the available image engines."
msgstr "Die AVIF-Erzeugung mit den verfügbaren Bildmodulen ist fehlgeschlagen."

msgid "The generated AVIF file size could not be read."
msgstr "Die Größe der erzeugten AVIF-Datei konnte nicht gelesen werden."


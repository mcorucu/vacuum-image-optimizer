msgid "Scanning library…"
msgstr "Analizando la biblioteca…"

msgid "Processing queue…"
msgstr "Procesando la cola…"

msgid "The queue request could not be completed."
msgstr "No se pudo completar la solicitud de la cola."

msgid "Vacuum Image Optimizer"
msgstr "Vacuum Image Optimizer"

msgid "Vacuum Optimizer"
msgstr "Vacuum Optimizer"

msgid "Sorry, you are not allowed to access this page."
msgstr "Lo sentimos, no tienes permiso para acceder a esta página."

msgid "Modern image optimization for WordPress — WebP &amp; AVIF generation, bulk tools, and clean delivery."
msgstr "Optimización de imágenes moderna para WordPress: generación de WebP &amp; AVIF, herramientas masivas y entrega limpia."

msgid "Vacuum Optimizer Sections"
msgstr "Secciones de Vacuum Optimizer"

msgid "Dashboard"
msgstr "Panel"

msgid "Bulk Optimize"
msgstr "Optimización masiva"

msgid "WebP & AVIF"
msgstr "WebP & AVIF"

msgid "Compression"
msgstr "Compresión"

msgid "Lazy Load"
msgstr "Carga diferida"

msgid "Backup & Restore"
msgstr "Copia de seguridad y restauración"

msgid "Exclusions"
msgstr "Exclusiones"

msgid "Reports"
msgstr "Informes"

msgid "System Status"
msgstr "Estado del sistema"

msgid "This feature is coming soon."
msgstr "Esta función estará disponible pronto."

msgid "Sorry, you are not allowed to manage these settings."
msgstr "Lo sentimos, no tienes permiso para gestionar estos ajustes."

msgid "Backups are disabled. New optimizations will not create restore points, and restore actions for images without an existing backup will be unavailable. Existing backups remain untouched."
msgstr "Las copias de seguridad están desactivadas. Las nuevas optimizaciones no crearán puntos de restauración y la restauración de imágenes sin copia de seguridad existente no estará disponible. Las copias existentes permanecen intactas."

msgid "Enable Backups"
msgstr "Activar copias de seguridad"

msgid "Keep a copy of each original image before generating optimized formats so it can be restored later."
msgstr "Conserva una copia de cada imagen original antes de generar formatos optimizados para poder restaurarla más adelante."

msgid "Backup Location"
msgstr "Ubicación de la copia de seguridad"

msgid "Uploads directory unavailable"
msgstr "Directorio de subidas no disponible"

msgid "Save Settings"
msgstr "Guardar ajustes"

msgid "Bulk Optimization"
msgstr "Optimización masiva"

msgid "Scan eligible JPEG and PNG images, then process the queue in safe WordPress AJAX batches."
msgstr "Analiza las imágenes JPEG y PNG aptas y luego procesa la cola en lotes AJAX seguros de WordPress."

msgid "Scan Library"
msgstr "Analizar biblioteca"

msgid "Start Queue"
msgstr "Iniciar cola"

msgid "Pause Queue"
msgstr "Pausar cola"

msgid "Resume Queue"
msgstr "Reanudar cola"

msgid "Queue Progress"
msgstr "Progreso de la cola"


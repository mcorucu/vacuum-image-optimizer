msgid "Vacuum Image Optimizer requires PHP 8.1 or higher."
msgstr "Vacuum Image Optimizer requiere PHP 8.1 o superior."

msgid "Plugin Activation Error"
msgstr "Error de activación del plugin"

msgid "Invalid attachment ID."
msgstr "ID de adjunto no válido."

msgid "Attachment could not be found."
msgstr "No se pudo encontrar el adjunto."

msgid "This attachment format is not supported for AVIF generation."
msgstr "Este formato de adjunto no es compatible con la generación de AVIF."

msgid "AVIF generation is not available on this server."
msgstr "La generación de AVIF no está disponible en este servidor."

msgid "The original image path could not be resolved."
msgstr "No se pudo resolver la ruta de la imagen original."

msgid "The original image file is missing or unreadable."
msgstr "El archivo de la imagen original falta o no se puede leer."

msgid "The original image file size could not be read."
msgstr "No se pudo leer el tamaño del archivo de la imagen original."

msgid "The AVIF output path could not be created."
msgstr "No se pudo crear la ruta de salida del AVIF."

msgid "Existing AVIF file found. Metadata was refreshed."
msgstr "Se encontró un archivo AVIF existente. Se actualizaron los metadatos."

msgid "No available image engine can generate AVIF on this server."
msgstr "Ningún motor de imagen disponible puede generar AVIF en este servidor."

msgid "AVIF generation failed with the available image engines."
msgstr "La generación de AVIF falló con los motores de imagen disponibles."

msgid "The generated AVIF file size could not be read."
msgstr "No se pudo leer el tamaño del archivo AVIF generado."

msgid "AVIF image generated successfully."
msgstr "Imagen AVIF generada correctamente."

msgid "The original backup file is missing or unreadable."
msgstr "El archivo de copia de seguridad original falta o no se puede leer."

msgid "The attachment original path could not be resolved."
msgstr "No se pudo resolver la ruta original del adjunto."

msgid "The original image directory could not be created."
msgstr "No se pudo crear el directorio de la imagen original."

msgid "The original image could not be restored from backup."
msgstr "No se pudo restaurar la imagen original desde la copia de seguridad."

msgid "Original image restored successfully."
msgstr "Imagen original restaurada correctamente."

msgid "This attachment format is not supported for WebP generation."
msgstr "Este formato de adjunto no es compatible con la generación de WebP."

msgid "The WebP output path could not be created."
msgstr "No se pudo crear la ruta de salida del WebP."

msgid "The original image backup could not be created."
msgstr "No se pudo crear la copia de seguridad de la imagen original."

msgid "Existing WebP file found. Metadata was refreshed."
msgstr "Se encontró un archivo WebP existente. Se actualizaron los metadatos."

msgid "No available image engine can generate WebP on this server."
msgstr "Ningún motor de imagen disponible puede generar WebP en este servidor."

msgid "WebP generation failed with the available image engines."
msgstr "La generación de WebP falló con los motores de imagen disponibles."

msgid "The generated WebP file size could not be read."
msgstr "No se pudo leer el tamaño del archivo WebP generado."

msgid "WebP image generated successfully."
msgstr "Imagen WebP generada correctamente."

msgid "Sorry, you are not allowed to manage this attachment."
msgstr "Lo sentimos, no tienes permiso para gestionar este adjunto."

msgid "Backups are disabled, so no backup is available to restore this image. Enable backups before optimizing to allow restores."
msgstr "Las copias de seguridad están desactivadas, por lo que no hay ninguna copia disponible para restaurar esta imagen. Activa las copias antes de optimizar para permitir las restauraciones."

msgid "Existing WebP file could not be deleted before regeneration."
msgstr "No se pudo eliminar el archivo WebP existente antes de la regeneración."

msgid "WebP generation could not be completed."
msgstr "No se pudo completar la generación de WebP."

msgid "AVIF generation could not be completed."
msgstr "No se pudo completar la generación de AVIF."

msgid "WebP regeneration could not be completed."
msgstr "No se pudo completar la regeneración de WebP."

msgid "Original image restore could not be completed."
msgstr "No se pudo completar la restauración de la imagen original."

msgid "The requested attachment action is invalid."
msgstr "La acción solicitada sobre el adjunto no es válida."

msgid "Vacuum Image Optimizer actions are available for image attachments only."
msgstr "Las acciones de Vacuum Image Optimizer solo están disponibles para adjuntos de imagen."


msgid "Invalid attachment ID."
msgstr "ID de anexo inválido."

msgid "Attachment could not be found."
msgstr "Não foi possível encontrar o anexo."

msgid "This attachment format is not supported for AVIF generation."
msgstr "Este formato de anexo não é suportado para a geração de AVIF."

msgid "AVIF generation is not available on this server."
msgstr "A geração de AVIF não está disponível neste servidor."

msgid "The original image path could not be resolved."
msgstr "Não foi possível resolver o caminho da imagem original."

msgid "The original image file is missing or unreadable."
msgstr "O ficheiro da imagem original está em falta ou ilegível."

msgid "The original image file size could not be read."
msgstr "Não foi possível ler o tamanho do ficheiro da imagem original."

msgid "The AVIF output path could not be created."
msgstr "Não foi possível criar o caminho de saída do AVIF."

msgid "Existing AVIF file found. Metadata was refreshed."
msgstr "Ficheiro AVIF existente encontrado. Os metadados foram atualizados."

msgid "No available image engine can generate AVIF on this server."
msgstr "Nenhum motor de imagem disponível consegue gerar AVIF neste servidor."

msgid "AVIF generation failed with the available image engines."
msgstr "A geração de AVIF falhou com os motores de imagem disponíveis."

msgid "The generated AVIF file size could not be read."
msgstr "Não foi possível ler o tamanho do ficheiro AVIF gerado."

msgid "AVIF image generated successfully."
msgstr "Imagem AVIF gerada com sucesso."

msgid "The original backup file is missing or unreadable."
msgstr "O ficheiro de cópia de segurança original está em falta ou ilegível."

msgid "The attachment original path could not be resolved."
msgstr "Não foi possível resolver o caminho original do anexo."

msgid "The original image directory could not be created."
msgstr "Não foi possível criar o diretório da imagem original."

msgid "The original image could not be restored from backup."
msgstr "Não foi possível restaurar a imagem original a partir da cópia de segurança."

msgid "Original image restored successfully."
msgstr "Imagem original restaurada com sucesso."

msgid "This attachment format is not supported for WebP generation."
msgstr "Este formato de anexo não é suportado para a geração de WebP."

msgid "The WebP output path could not be created."
msgstr "Não foi possível criar o caminho de saída do WebP."

msgid "The original image backup could not be created."
msgstr "Não foi possível criar a cópia de segurança da imagem original."

msgid "Existing WebP file found. Metadata was refreshed."
msgstr "Ficheiro WebP existente encontrado. Os metadados foram atualizados."

msgid "No available image engine can generate WebP on this server."
msgstr "Nenhum motor de imagem disponível consegue gerar WebP neste servidor."

msgid "WebP generation failed with the available image engines."
msgstr "A geração de WebP falhou com os motores de imagem disponíveis."

msgid "The generated WebP file size could not be read."
msgstr "Não foi possível ler o tamanho do ficheiro WebP gerado."

msgid "WebP image generated successfully."
msgstr "Imagem WebP gerada com sucesso."

msgid "Sorry, you are not allowed to manage this attachment."
msgstr "Lamentamos, mas não tem permissão para gerir este anexo."

msgid "Backups are disabled, so no backup is available to restore this image. Enable backups before optimizing to allow restores."
msgstr "As cópias de segurança estão desativadas, por isso não há nenhuma cópia disponível para restaurar esta imagem. Ative as cópias antes de otimizar para permitir os restauros."

msgid "Existing WebP file could not be deleted before regeneration."
msgstr "Não foi possível eliminar o ficheiro WebP existente antes da regeneração."

msgid "WebP generation could not be completed."
msgstr "Não foi possível concluir a geração de WebP."

msgid "AVIF generation could not be completed."
msgstr "Não foi possível concluir a geração de AVIF."

msgid "WebP regeneration could not be completed."
msgstr "Não foi possível concluir a regeneração de WebP."

msgid "Original image restore could not be completed."
msgstr "Não foi possível concluir o restauro da imagem original."

msgid "The requested attachment action is invalid."
msgstr "A ação de anexo solicitada é inválida."

msgid "Vacuum Image Optimizer actions are available for image attachments only."
msgstr "As ações do Vacuum Image Optimizer estão disponíveis apenas para anexos de imagem."


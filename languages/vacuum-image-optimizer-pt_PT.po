msgid "Scanning library…"
msgstr "A analisar a biblioteca…"

msgid "Processing queue…"
msgstr "A processar a fila…"

msgid "The queue request could not be completed."
msgstr "Não foi possível concluir o pedido da fila."

msgid "Vacuum Image Optimizer"
msgstr "Vacuum Image Optimizer"

msgid "Vacuum Optimizer"
msgstr "Vacuum Optimizer"

msgid "Sorry, you are not allowed to access this page."
msgstr "Lamentamos, mas não tem permissão para aceder a esta página."

msgid "Modern image optimization for WordPress — WebP &amp; AVIF generation, bulk tools, and clean delivery."
msgstr "Otimização de imagens moderna para WordPress — geração de WebP &amp; AVIF, ferramentas em massa e entrega limpa."

msgid "Vacuum Optimizer Sections"
msgstr "Secções do Vacuum Optimizer"

msgid "Dashboard"
msgstr "Painel"

msgid "Bulk Optimize"
msgstr "Otimização em massa"

msgid "WebP & AVIF"
msgstr "WebP & AVIF"

msgid "Compression"
msgstr "Compressão"

msgid "Lazy Load"
msgstr "Carregamento diferido"

msgid "Backup & Restore"
msgstr "Cópia de segurança e restauro"

msgid "Exclusions"
msgstr "Exclusões"

msgid "Reports"
msgstr "Relatórios"

msgid "System Status"
msgstr "Estado do sistema"

msgid "This feature is coming soon."
msgstr "Esta funcionalidade estará disponível em breve."

msgid "Sorry, you are not allowed to manage these settings."
msgstr "Lamentamos, mas não tem permissão para gerir estas definições."

msgid "Backups are disabled. New optimizations will not create restore points, and restore actions for images without an existing backup will be unavailable. Existing backups remain untouched."
msgstr "As cópias de segurança estão desativadas. As novas otimizações não criarão pontos de restauro e o restauro de imagens sem uma cópia existente não estará disponível. As cópias existentes permanecem inalteradas."

msgid "Enable Backups"
msgstr "Ativar cópias de segurança"

msgid "Keep a copy of each original image before generating optimized formats so it can be restored later."
msgstr "Mantenha uma cópia de cada imagem original antes de gerar formatos otimizados, para que possa ser restaurada mais tarde."

msgid "Backup Location"
msgstr "Localização da cópia de segurança"

msgid "Uploads directory unavailable"
msgstr "Diretório de carregamentos indisponível"

msgid "Save Settings"
msgstr "Guardar definições"

msgid "Bulk Optimization"
msgstr "Otimização em massa"

msgid "Scan eligible JPEG and PNG images, then process the queue in safe WordPress AJAX batches."
msgstr "Analise as imagens JPEG e PNG elegíveis e, em seguida, processe a fila em lotes AJAX seguros do WordPress."

msgid "Scan Library"
msgstr "Analisar biblioteca"

msgid "Start Queue"
msgstr "Iniciar fila"

msgid "Pause Queue"
msgstr "Pausar fila"

msgid "Resume Queue"
msgstr "Retomar fila"

msgid "Queue Progress"
msgstr "Progresso da fila"

msgid "Total"
msgstr "Total"

msgid "Pending"
msgstr "Pendente"

msgid "Processing"
msgstr "Em processamento"

msgid "Completed"
msgstr "Concluído"

msgid "Failed"
msgstr "Falhou"


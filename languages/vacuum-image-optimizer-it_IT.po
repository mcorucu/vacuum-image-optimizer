msgstr "Errore di attivazione del plugin"

msgid "Invalid attachment ID."
msgstr "ID allegato non valido."

msgid "Attachment could not be found."
msgstr "Impossibile trovare l'allegato."

msgid "This attachment format is not supported for AVIF generation."
msgstr "Questo formato di allegato non è supportato per la generazione AVIF."

msgid "AVIF generation is not available on this server."
msgstr "La generazione AVIF non è disponibile su questo server."

msgid "The original image path could not be resolved."
msgstr "Impossibile risolvere il percorso dell'immagine originale."

msgid "The original image file is missing or unreadable."
msgstr "Il file dell'immagine originale è mancante o illeggibile."

msgid "The original image file size could not be read."
msgstr "Impossibile leggere la dimensione del file dell'immagine originale."

msgid "The AVIF output path could not be created."
msgstr "Impossibile creare il percorso di output AVIF."

msgid "Existing AVIF file found. Metadata was refreshed."
msgstr "Trovato un file AVIF esistente. I metadati sono stati aggiornati."

msgid "No available image engine can generate AVIF on this server."
msgstr "Nessun motore immagine disponibile può generare AVIF su questo server."

msgid "AVIF generation failed with the available image engines."
msgstr "La generazione AVIF non è riuscita con i motori immagine disponibili."

msgid "The generated AVIF file size could not be read."
msgstr "Impossibile leggere la dimensione del file AVIF generato."

msgid "AVIF image generated successfully."
msgstr "Immagine AVIF generata correttamente."

msgid "The original backup file is missing or unreadable."
msgstr "Il file di backup originale è mancante o illeggibile."

msgid "The attachment original path could not be resolved."
msgstr "Impossibile risolvere il percorso originale dell'allegato."

msgid "The original image directory could not be created."
msgstr "Impossibile creare la cartella dell'immagine originale."

msgid "The original image could not be restored from backup."
msgstr "Impossibile ripristinare l'immagine originale dal backup."

msgid "Original image restored successfully."
msgstr "Immagine originale ripristinata correttamente."

msgid "This attachment format is not supported for WebP generation."
msgstr "Questo formato di allegato non è supportato per la generazione WebP."

msgid "The WebP output path could not be created."
msgstr "Impossibile creare il percorso di output WebP."

msgid "The original image backup could not be created."
msgstr "Impossibile creare il backup dell'immagine originale."

msgid "Existing WebP file found. Metadata was refreshed."
msgstr "Trovato un file WebP esistente. I metadati sono stati aggiornati."

msgid "No available image engine can generate WebP on this server."
msgstr "Nessun motore immagine disponibile può generare WebP su questo server."

msgid "WebP generation failed with the available image engines."
msgstr "La generazione WebP non è riuscita con i motori immagine disponibili."

msgid "The generated WebP file size could not be read."
msgstr "Impossibile leggere la dimensione del file WebP generato."

msgid "WebP image generated successfully."
msgstr "Immagine WebP generata correttamente."

msgid "Sorry, you are not allowed to manage this attachment."
msgstr "Spiacenti, non hai i permessi per gestire questo allegato."

msgid "Backups are disabled, so no backup is available to restore this image. Enable backups before optimizing to allow restores."
msgstr "I backup sono disattivati, quindi non è disponibile alcun backup per ripristinare questa immagine. Attiva i backup prima di ottimizzare per consentire i ripristini."

msgid "Existing WebP file could not be deleted before regeneration."
msgstr "Impossibile eliminare il file WebP esistente prima della rigenerazione."

msgid "WebP generation could not be completed."
msgstr "Impossibile completare la generazione WebP."

msgid "AVIF generation could not be completed."
msgstr "Impossibile completare la generazione AVIF."

msgid "WebP regeneration could not be completed."
msgstr "Impossibile completare la rigenerazione WebP."

msgid "Original image restore could not be completed."
msgstr "Impossibile completare il ripristino dell'immagine originale."

msgid "The requested attachment action is invalid."
msgstr "L'azione richiesta sull'allegato non è valida."

msgid "Vacuum Image Optimizer actions are available for image attachments only."
msgstr "Le azioni di Vacuum Image Optimizer sono disponibili solo per gli allegati immagine."


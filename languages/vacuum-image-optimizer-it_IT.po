msgid "Scanning library…"
msgstr "Scansione della libreria…"

msgid "Processing queue…"
msgstr "Elaborazione della coda…"

msgid "The queue request could not be completed."
msgstr "Impossibile completare la richiesta della coda."

msgid "Vacuum Image Optimizer"
msgstr "Vacuum Image Optimizer"

msgid "Vacuum Optimizer"
msgstr "Vacuum Optimizer"

msgid "Sorry, you are not allowed to access this page."
msgstr "Spiacenti, non hai i permessi per accedere a questa pagina."

msgid "Modern image optimization for WordPress — WebP &amp; AVIF generation, bulk tools, and clean delivery."
msgstr "Ottimizzazione delle immagini moderna per WordPress — generazione WebP &amp; AVIF, strumenti di massa e distribuzione pulita."

msgid "Vacuum Optimizer Sections"
msgstr "Sezioni di Vacuum Optimizer"

msgid "Dashboard"
msgstr "Bacheca"

msgid "Bulk Optimize"
msgstr "Ottimizzazione di massa"

msgid "WebP & AVIF"
msgstr "WebP & AVIF"

msgid "Compression"
msgstr "Compressione"

msgid "Lazy Load"
msgstr "Caricamento lazy"

msgid "Backup & Restore"
msgstr "Backup e ripristino"

msgid "Exclusions"
msgstr "Esclusioni"

msgid "Reports"
msgstr "Rapporti"

msgid "System Status"
msgstr "Stato del sistema"

msgid "This feature is coming soon."
msgstr "Questa funzionalità sarà presto disponibile."

msgid "Sorry, you are not allowed to manage these settings."
msgstr "Spiacenti, non hai i permessi per gestire queste impostazioni."

msgid "Backups are disabled. New optimizations will not create restore points, and restore actions for images without an existing backup will be unavailable. Existing backups remain untouched."
msgstr "I backup sono disattivati. Le nuove ottimizzazioni non creeranno punti di ripristino e il ripristino delle immagini senza un backup esistente non sarà disponibile. I backup esistenti rimangono invariati."

msgid "Enable Backups"
msgstr "Attiva i backup"

msgid "Keep a copy of each original image before generating optimized formats so it can be restored later."
msgstr "Conserva una copia di ogni immagine originale prima di generare i formati ottimizzati, così da poterla ripristinare in seguito."

msgid "Backup Location"
msgstr "Posizione del backup"

msgid "Uploads directory unavailable"
msgstr "Cartella dei caricamenti non disponibile"

msgid "Save Settings"
msgstr "Salva impostazioni"

msgid "Bulk Optimization"
msgstr "Ottimizzazione di massa"

msgid "Scan eligible JPEG and PNG images, then process the queue in safe WordPress AJAX batches."
msgstr "Scansiona le immagini JPEG e PNG idonee, quindi elabora la coda in lotti AJAX sicuri di WordPress."

msgid "Scan Library"
msgstr "Scansiona la libreria"

msgid "Start Queue"
msgstr "Avvia la coda"

msgid "Pause Queue"
msgstr "Metti in pausa la coda"

msgid "Resume Queue"
msgstr "Riprendi la coda"

msgid "Queue Progress"
msgstr "Avanzamento della coda"


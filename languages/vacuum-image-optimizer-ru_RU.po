msgstr "Ошибка активации плагина"

msgid "Invalid attachment ID."
msgstr "Неверный идентификатор вложения."

msgid "Attachment could not be found."
msgstr "Не удалось найти вложение."

msgid "This attachment format is not supported for AVIF generation."
msgstr "Этот формат вложения не поддерживается для создания AVIF."

msgid "AVIF generation is not available on this server."
msgstr "Создание AVIF недоступно на этом сервере."

msgid "The original image path could not be resolved."
msgstr "Не удалось определить путь к оригинальному изображению."

msgid "The original image file is missing or unreadable."
msgstr "Файл оригинального изображения отсутствует или нечитаем."

msgid "The original image file size could not be read."
msgstr "Не удалось прочитать размер файла оригинального изображения."

msgid "The AVIF output path could not be created."
msgstr "Не удалось создать путь вывода AVIF."

msgid "Existing AVIF file found. Metadata was refreshed."
msgstr "Найден существующий файл AVIF. Метаданные обновлены."

msgid "No available image engine can generate AVIF on this server."
msgstr "Ни один доступный графический движок не может создать AVIF на этом сервере."

msgid "AVIF generation failed with the available image engines."
msgstr "Не удалось создать AVIF с помощью доступных графических движков."

msgid "The generated AVIF file size could not be read."
msgstr "Не удалось прочитать размер созданного файла AVIF."

msgid "AVIF image generated successfully."
msgstr "Изображение AVIF успешно создано."

msgid "The original backup file is missing or unreadable."
msgstr "Файл оригинальной резервной копии отсутствует или нечитаем."

msgid "The attachment original path could not be resolved."
msgstr "Не удалось определить исходный путь вложения."

msgid "The original image directory could not be created."
msgstr "Не удалось создать каталог оригинального изображения."

msgid "The original image could not be restored from backup."
msgstr "Не удалось восстановить оригинальное изображение из резервной копии."

msgid "Original image restored successfully."
msgstr "Оригинальное изображение успешно восстановлено."

msgid "This attachment format is not supported for WebP generation."
msgstr "Этот формат вложения не поддерживается для создания WebP."

msgid "The WebP output path could not be created."
msgstr "Не удалось создать путь вывода WebP."

msgid "The original image backup could not be created."
msgstr "Не удалось создать резервную копию оригинального изображения."

msgid "Existing WebP file found. Metadata was refreshed."
msgstr "Найден существующий файл WebP. Метаданные обновлены."

msgid "No available image engine can generate WebP on this server."
msgstr "Ни один доступный графический движок не может создать WebP на этом сервере."

msgid "WebP generation failed with the available image engines."
msgstr "Не удалось создать WebP с помощью доступных графических движков."

msgid "The generated WebP file size could not be read."
msgstr "Не удалось прочитать размер созданного файла WebP."

msgid "WebP image generated successfully."
msgstr "Изображение WebP успешно создано."

msgid "Sorry, you are not allowed to manage this attachment."
msgstr "Извините, у вас нет прав для управления этим вложением."

msgid "Backups are disabled, so no backup is available to restore this image. Enable backups before optimizing to allow restores."
msgstr "Резервные копии отключены, поэтому нет копии для восстановления этого изображения. Включите резервные копии перед оптимизацией, чтобы разрешить восстановление."

msgid "Existing WebP file could not be deleted before regeneration."
msgstr "Не удалось удалить существующий файл WebP перед пересозданием."

msgid "WebP generation could not be completed."
msgstr "Не удалось завершить создание WebP."

msgid "AVIF generation could not be completed."
msgstr "Не удалось завершить создание AVIF."

msgid "WebP regeneration could not be completed."
msgstr "Не удалось завершить пересоздание WebP."

msgid "Original image restore could not be completed."
msgstr "Не удалось завершить восстановление оригинального изображения."

msgid "The requested attachment action is invalid."
msgstr "Запрошенное действие с вложением недопустимо."

msgid "Vacuum Image Optimizer actions are available for image attachments only."
msgstr "Действия Vacuum Image Optimizer доступны только для вложений-изображений."


msgstr "Неизвестное вложение"

msgid "Sorry, you are not allowed to manage compression settings."
msgstr "Извините, у вас нет прав для управления настройками сжатия."

msgid "Compression Settings"
msgstr "Настройки сжатия"

msgid "Choose the compression profile and WebP quality used for manual WebP generation and regeneration."
msgstr "Выберите профиль сжатия и качество WebP, используемые при ручном создании и пересоздании WebP."

msgid "Compression Profile"
msgstr "Профиль сжатия"

msgid "Quality"
msgstr "Качество"

msgid "Higher values preserve more visual detail. Lower values usually reduce file size more aggressively."
msgstr "Более высокие значения сохраняют больше визуальных деталей. Более низкие значения обычно сильнее уменьшают размер файла."

msgid "Upload Automation"
msgstr "Автоматизация загрузок"

msgid "Enable auto optimization for new uploads"
msgstr "Включить автоматическую оптимизацию новых загрузок"

msgid "Automatically optimize new JPEG and PNG uploads."
msgstr "Автоматически оптимизировать новые загрузки JPEG и PNG."

msgid "Auto optimization mode"
msgstr "Режим автоматической оптимизации"

msgid "Queue new uploads"
msgstr "Добавлять новые загрузки в очередь"

msgid "New uploads are added to the optimization queue. You can process them from Bulk Optimize."
msgstr "Новые загрузки добавляются в очередь оптимизации. Вы можете обработать их в разделе «Массовая оптимизация»."

msgid "Optimize immediately"
msgstr "Оптимизировать сразу"

msgid "New uploads are optimized immediately after upload. Large uploads may take longer."
msgstr "Новые загрузки оптимизируются сразу после загрузки. Большие файлы могут обрабатываться дольше."

msgid "AVIF Generation"
msgstr "Создание AVIF"

msgid "Enable AVIF Generation"
msgstr "Включить создание AVIF"

msgid "AVIF typically provides smaller file sizes than WebP but may require more processing time."
msgstr "AVIF обычно даёт меньший размер файлов, чем WebP, но может требовать больше времени на обработку."

msgid "AVIF Quality"
msgstr "Качество AVIF"

msgid "Lower AVIF quality values usually reduce file size further. Range: 0–100."
msgstr "Более низкие значения качества AVIF обычно ещё больше уменьшают размер файла. Диапазон: 0–100."

msgid "Frontend Delivery"
msgstr "Доставка на сайте"

msgid "Enable Frontend Delivery"
msgstr "Включить доставку на сайте"

msgid "Serve generated WebP/AVIF images on the frontend. Original media files are never modified and the browser always falls back to the original when a derivative is unavailable."
msgstr "Показывайте созданные изображения WebP/AVIF на сайте. Оригинальные медиафайлы никогда не изменяются, и браузер всегда возвращается к оригиналу, когда производный файл недоступен."

msgid "Preferred Format"
msgstr "Предпочтительный формат"

msgid "Auto"
msgstr "Авто"

msgid "AVIF"
msgstr "AVIF"

msgid "WebP"
msgstr "WebP"

msgid "Auto: Serve AVIF when available, otherwise WebP, otherwise the original image."
msgstr "Авто: показывает AVIF при наличии, иначе WebP, иначе оригинальное изображение."

msgid "AVIF: Prefer AVIF and fall back to the original image."
msgstr "AVIF: отдаёт предпочтение AVIF и возвращается к оригинальному изображению."

msgid "WebP: Prefer WebP and fall back to the original image."
msgstr "WebP: отдаёт предпочтение WebP и возвращается к оригинальному изображению."


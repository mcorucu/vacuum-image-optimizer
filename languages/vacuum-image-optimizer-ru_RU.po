msgstr "Всего"

msgid "Pending"
msgstr "В очереди"

msgid "Processing"
msgstr "Обработка"

msgid "Completed"
msgstr "Завершено"

msgid "Failed"
msgstr "Ошибка"

msgid "Failed Jobs"
msgstr "Неудавшиеся задачи"


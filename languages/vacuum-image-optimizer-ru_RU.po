msgid "Scanning library…"
msgstr "Сканирование библиотеки…"

msgid "Processing queue…"
msgstr "Обработка очереди…"

msgid "The queue request could not be completed."
msgstr "Не удалось выполнить запрос очереди."

msgid "Vacuum Image Optimizer"
msgstr "Vacuum Image Optimizer"

msgid "Vacuum Optimizer"
msgstr "Vacuum Optimizer"

msgid "Sorry, you are not allowed to access this page."
msgstr "Извините, у вас нет прав для доступа к этой странице."

msgid "Modern image optimization for WordPress — WebP &amp; AVIF generation, bulk tools, and clean delivery."
msgstr "Современная оптимизация изображений для WordPress — создание WebP &amp; AVIF, массовые инструменты и аккуратная доставка."

msgid "Vacuum Optimizer Sections"
msgstr "Разделы Vacuum Optimizer"

msgid "Dashboard"
msgstr "Панель"

msgid "Bulk Optimize"
msgstr "Массовая оптимизация"

msgid "WebP & AVIF"
msgstr "WebP и AVIF"

msgid "Compression"
msgstr "Сжатие"

msgid "Lazy Load"
msgstr "Отложенная загрузка"

msgid "Backup & Restore"
msgstr "Резервная копия и восстановление"

msgid "Exclusions"
msgstr "Исключения"

msgid "Reports"
msgstr "Отчёты"

msgid "System Status"
msgstr "Состояние системы"

msgid "This feature is coming soon."
msgstr "Эта функция появится в ближайшее время."

msgid "Sorry, you are not allowed to manage these settings."
msgstr "Извините, у вас нет прав для управления этими настройками."

msgid "Backups are disabled. New optimizations will not create restore points, and restore actions for images without an existing backup will be unavailable. Existing backups remain untouched."
msgstr "Резервные копии отключены. Новые оптимизации не будут создавать точки восстановления, а восстановление изображений без существующей копии будет недоступно. Существующие копии остаются нетронутыми."

msgid "Enable Backups"
msgstr "Включить резервные копии"

msgid "Keep a copy of each original image before generating optimized formats so it can be restored later."
msgstr "Сохраняйте копию каждого оригинального изображения перед созданием оптимизированных форматов, чтобы его можно было восстановить позже."

msgid "Backup Location"
msgstr "Расположение резервной копии"

msgid "Uploads directory unavailable"
msgstr "Каталог загрузок недоступен"

msgid "Save Settings"
msgstr "Сохранить настройки"

msgid "Bulk Optimization"
msgstr "Массовая оптимизация"

msgid "Scan eligible JPEG and PNG images, then process the queue in safe WordPress AJAX batches."
msgstr "Просканируйте подходящие изображения JPEG и PNG, затем обработайте очередь безопасными AJAX-пакетами WordPress."

msgid "Scan Library"
msgstr "Сканировать библиотеку"

msgid "Start Queue"
msgstr "Запустить очередь"

msgid "Pause Queue"
msgstr "Приостановить очередь"

msgid "Resume Queue"
msgstr "Возобновить очередь"

msgid "Queue Progress"
msgstr "Ход выполнения очереди"


msgid "Generate WebP"
msgstr "Создавать WebP"

msgid "Enable WebP generation for all optimized images."
msgstr "Включить создание WebP для всех оптимизированных изображений."

msgid "Generate AVIF"
msgstr "Создавать AVIF"

msgid "Enable AVIF generation. Requires server support."
msgstr "Включить создание AVIF. Требуется поддержка сервера."

msgid "Fallback Chain"
msgstr "Цепочка возврата"

msgid "Browsers will use the first supported format."
msgstr "Браузеры будут использовать первый поддерживаемый формат."

msgid "Enable Lazy Loading"
msgstr "Включить отложенную загрузку"

msgid "Add native browser loading=\"lazy\" to frontend images. No JavaScript is used."
msgstr "Добавляет встроенный атрибут браузера loading=\"lazy\" к изображениям на сайте. JavaScript не используется."

msgid "Optimization history and statistics will appear here once you start optimizing images."
msgstr "История оптимизации и статистика появятся здесь, как только вы начнёте оптимизировать изображения."

